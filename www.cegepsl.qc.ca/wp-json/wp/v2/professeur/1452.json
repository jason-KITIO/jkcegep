{"id":1452,"date":"2019-08-06T18:12:15","date_gmt":"2019-08-06T22:12:15","guid":{"rendered":"https:\/\/staging.cegepsl.qc.ca\/?post_type=professeur&#038;p=1452"},"modified":"2023-06-12T12:04:36","modified_gmt":"2023-06-12T16:04:36","slug":"pier-luc-lampron","status":"publish","type":"professeur","link":"https:\/\/www.cegepsl.qc.ca\/equipe\/pier-luc-lampron\/","title":{"rendered":"Pier-Luc Lampron"},"content":{"rendered":"<p>Pier-Luc Lampron a r\u00e9alis\u00e9 un baccalaur\u00e9at et une maitrise en philosophie \u00e0 l\u2019Universit\u00e9 du Qu\u00e9bec \u00e0 Trois-Rivi\u00e8res. Il enseigne la philosophie au c\u00e9gep de Saint-Laurent depuis la session d\u2019automne 2004. Ses champs d\u2019investigation philosophique de pr\u00e9dilection sont l\u2019ontologie, l\u2019\u00e9pist\u00e9mologie et la ph\u00e9nom\u00e9nologie. En plus de sa passion pour la pratique de la philosophie, il est \u00e9galement passionn\u00e9 de musique, de guitare et de production musicale.<\/p>\n","protected":false},"featured_media":1453,"template":"","categorie-equipe":[202],"departement-equipe":[301],"specialite-equipe":[],"etiquette-interne":[],"class_list":["post-1452","professeur","type-professeur","status-publish","has-post-thumbnail","hentry","categorie-equipe-personnel-enseignant","departement-equipe-philosophie"],"acf":[],"publishpress_future_workflow_manual_trigger":{"enabledWorkflows":[]},"_links":{"self":[{"href":"https:\/\/www.cegepsl.qc.ca\/wp-json\/wp\/v2\/professeur\/1452","targetHints":{"allow":["GET"]}}],"collection":[{"href":"https:\/\/www.cegepsl.qc.ca\/wp-json\/wp\/v2\/professeur"}],"about":[{"href":"https:\/\/www.cegepsl.qc.ca\/wp-json\/wp\/v2\/types\/professeur"}],"wp:featuredmedia":[{"embeddable":true,"href":"https:\/\/www.cegepsl.qc.ca\/wp-json\/wp\/v2\/media\/1453"}],"wp:attachment":[{"href":"https:\/\/www.cegepsl.qc.ca\/wp-json\/wp\/v2\/media?parent=1452"}],"wp:term":[{"taxonomy":"categorie-equipe","embeddable":true,"href":"https:\/\/www.cegepsl.qc.ca\/wp-jso